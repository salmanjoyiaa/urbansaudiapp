{
  "expo": {
    "name": "UrbanSaudi Admin",
    "slug": "urbansaudi-mobile-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "urbansaudiadmin",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F5F0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.salmanjoyiaa.urbansaudimobileadmin",
      "supportsTablet": true
    },
    "android": {
      "package": "com.salmanjoyiaa.urbansaudimobileadmin",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#021540"
      },
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "88d0fb7f-9420-4f07-b1b3-bb485b2e33b2"
      }
    }
  }
}
